# ── Copy this file to backend/.env and fill in values ──────────────────────
# cp .env.example backend/.env

# ── Ollama (Local LLM) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
GENERAL_MODEL=llama3
CODER_MODEL=deepseek-coder
EMBEDDING_MODEL=nomic-embed-text

# ── Memory / Storage ────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma
SKILL_DB_PATH=./data/skills.db
CAPABILITIES_DIR=./data/capabilities
EVOLUTION_LOG_PATH=./data/evolution.jsonl

# ── Agent Settings ───────────────────────────────────────────────────────────
MAX_MEMORY_RESULTS=5
MAX_ITERATIONS=5
DEFAULT_REASONING=auto
MAX_PLAN_STEPS=6
MIN_SCORE_TO_LEARN=6.0
MIN_GAP_CONFIDENCE=0.6

# ── Self-Healing ─────────────────────────────────────────────────────────────
HEAL_INTERVAL_SEC=60
AUTO_EXPAND_ON_FAIL=true

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
MAX_CODE_RUNTIME=20
TOOL_TIMEOUT=30
