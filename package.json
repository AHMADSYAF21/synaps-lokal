{
  "name": "synapse-local-frontend",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev":             "vite --host 0.0.0.0 --port 3000",
    "build":           "vite build",
    "build:electron":  "vite build --mode electron",
    "build:android":   "vite build --mode android",
    "preview":         "vite preview --host 0.0.0.0 --port 3000",
    "cap:add:android": "npx cap add android",
    "cap:sync":        "npx cap sync android",
    "cap:open":        "npx cap open android",
    "cap:build":       "npm run build:android && npx cap sync android",
    "apk:debug":       "npm run cap:build && cd android && ./gradlew assembleDebug",
    "apk:release":     "npm run cap:build && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "react":                   "^18.3.1",
    "react-dom":               "^18.3.1",
    "@capacitor/core":         "^6.1.0",
    "@capacitor/android":      "^6.1.0",
    "@capacitor/splash-screen":"^6.0.2",
    "@capacitor/status-bar":   "^6.0.1",
    "@capacitor/preferences":  "^6.0.2",
    "@capacitor/network":      "^6.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite":                 "^5.3.1",
    "@capacitor/cli":       "^6.1.0"
  }
}
