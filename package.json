{
  "name": "synapse-local",
  "version": "3.0.0",
  "description": "Synapse Local — Autonomous AI, 100% Offline",
  "main": "main.js",
  "author": "Synapse",
  "license": "MIT",
  "private": true,

  "scripts": {
    "start":         "electron .",
    "dev":           "ELECTRON_IS_DEV=1 electron .",
    "build:win":     "electron-builder --win",
    "build:mac":     "electron-builder --mac",
    "build:linux":   "electron-builder --linux",
    "build:all":     "electron-builder --win --mac --linux",
    "dist":          "npm run build:linux"
  },

  "dependencies": {},

  "devDependencies": {
    "electron":           "^31.0.0",
    "electron-builder":   "^24.13.3"
  },

  "build": {
    "appId":       "com.synapse.local",
    "productName": "Synapse Local",
    "copyright":   "Synapse Local v3",

    "directories": {
      "output": "../dist-electron",
      "buildResources": "assets"
    },

    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "assets/**",
      "../backend/**",
      "../frontend/dist/**",
      "!../backend/.venv/**",
      "!../backend/data/**",
      "!../backend/__pycache__/**",
      "!../backend/core/__pycache__/**",
      "!../frontend/node_modules/**",
      "!../frontend/src/**"
    ],

    "extraResources": [
      { "from": "../backend", "to": "app/backend",  "filter": ["**/*", "!.venv/**", "!data/**", "!**/__pycache__/**"] },
      { "from": "../frontend/dist", "to": "app/frontend/dist" }
    ],

    "win": {
      "target":     [{ "target": "nsis", "arch": ["x64"] }],
      "icon":       "assets/icon.ico",
      "artifactName": "Synapse-Local-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick":              false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon":         "assets/icon.ico",
      "uninstallerIcon":       "assets/icon.ico",
      "installerHeaderIcon":   "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName":          "Synapse Local"
    },

    "mac": {
      "target":     [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon":       "assets/icon.icns",
      "category":   "public.app-category.productivity",
      "artifactName": "Synapse-Local-${version}.${ext}"
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },

    "linux": {
      "target":     [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "icon":       "assets/icon.png",
      "category":   "Utility",
      "artifactName": "Synapse-Local-${version}.${ext}"
    }
  }
}
